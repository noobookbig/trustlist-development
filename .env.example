# Trustlist App — local environment template
# ----------------------------------------------------------------------
# Copy this file to `.env` and replace every CHANGE_ME placeholder.
# `.env` is gitignored; never commit real secrets.
#
# Generate strong values locally with:
#   openssl rand -base64 48        # for MSSQL_SA_PASSWORD (>=16 chars recommended)
#   openssl rand -base64 48        # for JWT_SIGNING_KEY (must be >=32 bytes when UTF-8 decoded)
# ----------------------------------------------------------------------

# --- MS SQL Express `sa` password (local bring-up only) -----------------
MSSQL_SA_PASSWORD=CHANGE_ME_strong_sa_password_at_least_16_chars

# --- JWT signing key (HS256) --------------------------------------------
# Must be at least 32 bytes when UTF-8 encoded. Generate with:
#   openssl rand -base64 48
JWT_SIGNING_KEY=CHANGE_ME_at_least_32_byte_random_signing_key

# --- JWT claims (defaults shown; override per environment) ---------------
JWT_ISSUER=trustlist-api
JWT_AUDIENCE=trustlist-web
JWT_EXPIRY_MINUTES=120

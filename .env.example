# Trustlist App — local environment template
# ----------------------------------------------------------------------
# Copy this file to `.env` and replace every CHANGE_ME placeholder.
# `.env` is gitignored; never commit real secrets.
#
# Generate strong values locally with:
#   openssl rand -base64 48        # for MSSQL_SA_PASSWORD (>=16 chars recommended)
#   openssl rand -base64 48        # for JWT_SIGNING_KEY (must be >=32 bytes when UTF-8 decoded)
# ----------------------------------------------------------------------

# --- MS SQL Express `sa` password (local bring-up only) -----------------
# WARNING: MS SQL only applies this password on the FIRST init of the
# `mssql-data` volume. If you change it later while the old volume still
# exists, the db keeps the OLD password and startup fails with
# "dependency db failed to start" (Login failed for user 'sa'). After
# changing this value, reset the volume: `scripts/dev-db.sh reset`.
MSSQL_SA_PASSWORD=CHANGE_ME_strong_sa_password_at_least_16_chars

# --- JWT signing key (HS256) --------------------------------------------
# Must be at least 32 bytes when UTF-8 encoded. Generate with:
#   openssl rand -base64 48
JWT_SIGNING_KEY=CHANGE_ME_at_least_32_byte_random_signing_key

# --- JWT claims (defaults shown; override per environment) ---------------
JWT_ISSUER=trustlist-api
JWT_AUDIENCE=trustlist-web
JWT_EXPIRY_MINUTES=120

# --- Trustlist publisher signing key (Ed25519 seed, MAS-696) ----------------
# Signs every /v1/{role}/... directory response in JWS-compact form
# (RFC 7515 + RFC 8032). The matching public key is published at
# `/.well-known/trustlist-jwks.json` so Issuers / Wallets / Verifiers can verify
# signed responses with no out-of-band trust anchor. MUST be 32 bytes when
# base64-decoded (raw Ed25519 seed). Generate with:
#   openssl rand -base64 32
TRUSTLIST_PUBLISHER_PRIVATE_KEY=CHANGE_ME_32_byte_base64_Ed25519_seed

# Key id advertised in the JWS `protected` header and looked up in JWKS.
# Stable across rotations of the underlying seed; on rotation publish the new
# kid alongside the old one and let the JWKS-TTL window (24h, per v0 spec) expire
# before retiring the old key.
TRUSTLIST_PUBLISHER_KID=tl-publisher-2026-q2

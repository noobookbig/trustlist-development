@page "/login"
@rendermode InteractiveServer
@inject TrustlistApiClient Api
@inject AuthState Auth
@inject NavigationManager Nav

<section class="hero auth-hero" role="img" aria-label="Ray-traced neon spheres representing the Thai verifiable-credential trust network">
    <div class="hero-body">
        <span class="hero-eyebrow">Thailand Trust List</span>
        <h1>@(registerMode ? "Register" : "Login")</h1>

<div class="card auth-card">
    <label>
        Email
        <input type="email" @bind="email" placeholder="admin@trustlist.local" />
    </label>
    <label>
        Password
        <input type="password" @bind="password" placeholder="••••••••" />
    </label>

    @if (error is not null)
    {
        <p class="error">@error</p>
    }

    <button class="primary" @onclick="Submit" disabled="@busy">
        @(busy ? "Please wait…" : (registerMode ? "Create account" : "Sign in"))
    </button>

    <button class="link-btn" @onclick="Toggle">
        @(registerMode ? "Have an account? Login" : "Need an account? Register")
    </button>

    @if (!registerMode)
    {
        <p class="hint">Seeded admin: <code>admin@trustlist.local</code> / <code>Admin#12345</code></p>
    }
</div>
    </div>
</section>

@code {
    private string email = "";
    private string password = "";
    private string? error;
    private bool busy;
    private bool registerMode;

    private void Toggle()
    {
        registerMode = !registerMode;
        error = null;
    }

    private async Task Submit()
    {
        error = null;
        busy = true;
        try
        {
            var (result, err) = registerMode
                ? await Api.RegisterAsync(email, password)
                : await Api.LoginAsync(email, password);

            if (result is not null)
            {
                Auth.SignIn(new AuthResult(result.Token, result.Email, result.ExpiresAt));
                Nav.NavigateTo("/manage");
            }
            else
            {
                error = err ?? "Authentication failed.";
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
